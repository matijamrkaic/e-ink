# Copy this file to .env and fill in real values. .env is gitignored.
# config.py auto-loads it, so `python dashboard.py` picks these up — no need to
# export anything in your shell.
#
# _H = husband, _W = wife (matches config.PEOPLE).

GARMIN_EMAIL_H=him@example.com
GARMIN_PASSWORD_H=his-password

GARMIN_EMAIL_W=her@example.com
GARMIN_PASSWORD_W=her-password

GARMINTOKENS_H=
GARMINTOKENS_W=

# After the first successful run, each person's OAuth token is cached on disk
# (~/.garminconnect_h / _w), so the password isn't sent again on later runs.
#
# For CI you don't use email/password — you paste the printed one-line token
# blob into the GARMINTOKENS_H / GARMINTOKENS_W GitHub secrets instead.
